number rx ry
= rx 0
= ry 0

set_3d

function draw
{
	clear 100 100 255

	draw_3d_textured tex verts faces colours texcoords 12
}

function run
{
	+ rx 0.01
	+ ry 0.02
	identity_3d
	translate_3d 0 0 -5
	rotate_3d rx 1 0 0
	rotate_3d ry 0 1 0
}
